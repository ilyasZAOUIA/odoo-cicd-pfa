<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pipeline_demo_tree" model="ir.ui.view">
        <field name="name">pipeline.demo.tree</field>
        <field name="model">pipeline.demo</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_pipeline_demo_form" model="ir.ui.view">
        <field name="name">pipeline.demo.form</field>
        <field name="model">pipeline.demo</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="pipeline_demo_action" model="ir.actions.act_window">
        <field name="name">Pipeline Demo</field>
        <field name="res_model">pipeline.demo</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="pipeline_demo_root"
              name="Pipeline Demo"
              sequence="10"/>

    <menuitem id="pipeline_demo_menu"
              parent="pipeline_demo_root"
              name="Records"
              action="pipeline_demo_action"/>
</odoo>
